# --- LLM serving (OpenAI-compatible endpoint) ---
# Any OpenAI-compatible server works: Ollama, LM Studio, llama.cpp server, vLLM, or a cloud API.
# Ollama default shown. For vLLM use e.g. http://gpu-box:8000/v1
OPENAI_BASE_URL=http://localhost:11434/v1

# API key for the endpoint. Ollama ignores it but the client requires a value.
OPENAI_API_KEY=ollama

# Model name as known to the serving endpoint. Swap models here, never in code.
MODEL_NAME=qwen3.5:4b

# LLM request timeout in seconds. Small local models on laptops can be slow.
LLM_TIMEOUT_S=120

# Sampling temperature for the agent (low = more deterministic extraction).
LLM_TEMPERATURE=0.2

# Reasoning effort for thinking models (qwen3.5 family): "none" disables
# thinking tokens, keeping extraction fast on small local models.
# Leave empty to omit the parameter on backends that reject it.
LLM_REASONING_EFFORT=none

# --- Data ---
# Path to the SQLite model catalog (built by `make refresh-data`, seed ships in repo).
DB_PATH=data/models.db

# Path to the markdown knowledge base directory.
KB_DIR=kb

# Path to the hardware probe snippet library.
SNIPPETS_PATH=data/hardware_snippets.yaml

# Retrieval backend: hybrid (BM25 + embeddings, recommended), bm25, embedding.
# Hybrid needs the embedding model below (ollama pull nomic-embed-text) and
# silently degrades to BM25 if it is missing.
RETRIEVER_BACKEND=hybrid
EMBED_MODEL_NAME=nomic-embed-text
EMBED_CACHE_PATH=data/kb_embeddings.json

# Web search for questions the catalog cannot answer: ddgs (DuckDuckGo, no
# API key) or off. Search happens only when needed and is shown in the UI.
WEB_SEARCH=ddgs

# --- Server ---
HOST=127.0.0.1
PORT=8000

# Session time-to-live in seconds (in-memory session store).
SESSION_TTL_S=3600

# USD to INR rate used for cost displays (refreshed manually, approximate is fine).
USD_TO_INR=84.0

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
